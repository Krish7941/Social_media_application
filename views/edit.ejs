<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Post — Threadline</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <script src="https://cdn.tailwindcss.com"></script>
    <link
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600&display=swap"
        rel="stylesheet">
    <style>
        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --bg: #0a0a0f;
            --surface: #111118;
            --border: rgba(255, 255, 255, 0.07);
            --accent: #e8ff47;
            --accent2: #ff6b47;
            --text: #f0ede8;
            --muted: #6b6878;
        }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            min-height: 100vh;
        }

        /* NAVBAR */
        .navbar {
            position: sticky;
            top: 0;
            z-index: 100;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 40px;
            height: 64px;
            background: rgba(10, 10, 15, 0.85);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
        }

        .nav-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            color: var(--text);
        }

        .nav-dot {
            width: 28px;
            height: 28px;
            background: var(--accent);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .nav-name {
            font-family: 'Playfair Display', serif;
            font-size: 19px;
            font-weight: 700;
        }

        .back-btn {
            display: flex;
            align-items: center;
            gap: 7px;
            padding: 8px 16px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--border);
            border-radius: 8px;
            color: var(--muted);
            font-family: 'DM Sans', sans-serif;
            font-size: 13px;
            font-weight: 500;
            text-decoration: none;
            transition: all 0.2s;
        }

        .back-btn:hover {
            color: var(--text);
            border-color: rgba(255, 255, 255, 0.15);
        }

        /* MAIN */
        .main {
            max-width: 720px;
            margin: 0 auto;
            padding: 64px 40px;
            animation: fadeUp 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
        }

        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(24px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .page-label {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: var(--accent);
            font-weight: 600;
            margin-bottom: 16px;
        }

        .page-label::before {
            content: '';
            display: block;
            width: 20px;
            height: 1.5px;
            background: var(--accent);
        }

        .page-title {
            font-family: 'Playfair Display', serif;
            font-size: 48px;
            font-weight: 900;
            letter-spacing: -2px;
            line-height: 1.0;
            margin-bottom: 8px;
        }

        .page-sub {
            font-size: 14px;
            color: var(--muted);
            margin-bottom: 48px;
        }

        /* ORIGINAL POST PREVIEW */
        .original-preview {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 20px 24px;
            margin-bottom: 32px;
            position: relative;
            overflow: hidden;
        }

        .original-preview::before {
            content: 'Original';
            position: absolute;
            top: 14px;
            right: 16px;
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--muted);
            font-weight: 600;
        }

        .original-preview p {
            font-size: 14px;
            line-height: 1.7;
            color: var(--muted);
            font-style: italic;
            max-width: 90%;
        }

        /* EDIT FORM */
        .edit-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 32px;
            transition: border-color 0.2s;
        }

        .edit-card:focus-within {
            border-color: rgba(232, 255, 71, 0.25);
        }

        .field-label {
            display: block;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--muted);
            font-weight: 600;
            margin-bottom: 14px;
        }

        .edit-textarea {
            width: 100%;
            min-height: 200px;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 20px;
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            font-size: 16px;
            line-height: 1.7;
            resize: vertical;
            outline: none;
            transition: border-color 0.2s, background 0.2s;
            margin-bottom: 24px;
        }

        .edit-textarea:focus {
            border-color: rgba(232, 255, 71, 0.3);
            background: rgba(232, 255, 71, 0.02);
        }

        .btn-row {
            display: flex;
            gap: 12px;
            align-items: center;
        }

        .update-btn {
            padding: 13px 28px;
            background: var(--accent);
            color: #0a0a0f;
            border: none;
            border-radius: 10px;
            font-family: 'DM Sans', sans-serif;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.15s, box-shadow 0.15s;
            letter-spacing: 0.3px;
        }

        .update-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 8px 24px rgba(232, 255, 71, 0.25);
        }

        .cancel-btn {
            padding: 13px 24px;
            background: none;
            border: 1px solid var(--border);
            border-radius: 10px;
            color: var(--muted);
            font-family: 'DM Sans', sans-serif;
            font-size: 14px;
            font-weight: 500;
            text-decoration: none;
            transition: all 0.2s;
        }

        .cancel-btn:hover {
            color: var(--text);
            border-color: rgba(255, 255, 255, 0.15);
        }

        .char-count {
            margin-left: auto;
            font-size: 12px;
            color: var(--muted);
        }

        /* DANGER ZONE */
        .danger-zone {
            margin-top: 40px;
            padding: 20px 24px;
            background: rgba(255, 107, 71, 0.04);
            border: 1px solid rgba(255, 107, 71, 0.15);
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .danger-zone p {
            font-size: 13px;
            color: var(--muted);
        }

        .danger-zone p strong {
            display: block;
            font-size: 14px;
            color: rgba(240, 237, 232, 0.7);
            margin-bottom: 3px;
        }

        .delete-hint {
            font-size: 12px;
            color: rgba(255, 107, 71, 0.5);
            font-style: italic;
        }

        @media (max-width: 640px) {
            .navbar {
                padding: 0 20px;
            }

            .main {
                padding: 40px 20px;
            }

            .page-title {
                font-size: 36px;
            }
        }
    </style>
</head>

<body>

    <!-- NAVBAR -->
    <nav class="navbar">
        <a href="/profile" class="nav-brand">
            <div class="nav-dot">
                <svg viewBox="0 0 16 16" width="14" height="14" fill="#0a0a0f">
                    <path d="M8 2L10.5 7H14L11 10L12.5 14L8 11.5L3.5 14L5 10L2 7H5.5L8 2Z" />
                </svg>
            </div>
            <span class="nav-name">Threadline</span>
        </a>

        <a href="/profile" class="back-btn">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 12H5M12 19l-7-7 7-7" />
            </svg>
            Back to Feed
        </a>
    </nav>

    <main class="main">
        <span class="page-label">Editing</span>
        <h1 class="page-title">Refine<br>your words.</h1>
        <p class="page-sub">Make it better. Every edit counts.</p>

        <div class="original-preview">
            <p>
                <%= post.content %>
            </p>
        </div>

        <div class="edit-card">
            <form action="/update/<%= post._id %>" method="post">
                <label class="field-label">Updated content</label>
                <textarea class="edit-textarea" name="content" id="editArea" placeholder="Rewrite your post..."
                    oninput="updateCount(this)"><%= post.content %></textarea>

                <div class="btn-row">
                    <button type="submit" class="update-btn">Save Changes →</button>
                    <form action="/delete/<%= post._id %>" method="POST">
                        <button class="bg-red-500 text-white px-5 py-3 rounded-xl">
                            Delete
                        </button>
                    </form>
                    <a href="/profile" class="cancel-btn">Cancel</a>
                    <span class="char-count" id="charCount">— chars</span>
                </div>
            </form>
        </div>

    </main>

    <script>
        function updateCount(el) {
            document.getElementById('charCount').textContent = el.value.length + ' chars';
        }
        // init on load
        const ta = document.getElementById('editArea');
        if (ta) updateCount(ta);
    </script>

</body>

</html>