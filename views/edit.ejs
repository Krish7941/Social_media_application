<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-6">
        <h5 class="mb-5">Edit your post</h5>
        <form action="/update/<%= post._id %>" method="post">
            <textarea class="p-3 outline-no w-1/3 resize-none bg-transparent border-2 border-zinc-800 rounded-md block"
                placeholder="What's on your mind?" id="" name="content"><%= post.content %></textarea>
            <button class="px-3 py-2 w-40 bg-yellow-500 text-black rounded-md mt-2 block" type="submit">Update
                Post</button>
        </form>
        
    </div>
</body>

</html>