<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white ">
        <div class="w-full flex justify-end">
            <a class="bg-red-500 rounded-md px-3 py-2 text-sm mb-5 mt-5 inline-block" href="/logout">Logout</a>
        </div>
        <h4>Welcome , <%=user.name %>
        </h4>
        <h5 class="mb-5">You can create a new post</h5>
        <form action="/post" method="post">
            <textarea class="p-3 outline-no w-1/3 resize-none bg-transparent border-2 border-zinc-800 rounded-md block"
                placeholder="What's on your mind?" id="" name="content"></textarea>
            <button class="px-3 py-2 w-40 bg-blue-500 text-white rounded-md mt-2 block" type="submit">Create
                Post</button>
        </form>
        <div class="posts mt-20">
            <h2 class="text-zinc-400">Your Posts</h2>
            <div class="postcontainer mt-5">
                <% user.posts.reverse().forEach(function(post){ %>
                    <div class="post w-1/3 p-4 mb-5 rounded-md bg-zinc-800 border-2 border-zinc-700">
                        <h4 class="text-blue-500 mb-2">
                            <%= user.username %>
                        </h4>
                        <p class="text-[10px] tracking-tight text-green-400 mb-3">
                            <%= new Date(post.date).toISOString().split('T')[0] %>
                        </p>
                        <p class="text-sm tracking-tight">
                            <%= post.content %>
                        </p>
                        <small class="inline-block mt-2"><%= post.likes ? post.likes.length : 0 %> Likes</small>
                        <div class="btns flex gap-3 mt-4">
                            
                            <a class="text-blue-500 ml-1" href="/like/<%= post._id %>">
                                <%= post.likes.indexOf(user._id) === -1 ? "Like" : "Unlike" %>
                            </a>
                            <a href="/edit/<%= post._id %>" class="text-zinc-600">Edit</a>
                        </div>
                    </div>
                    <% }) %>
            </div>
        </div>
    </div>
</body>

</html>