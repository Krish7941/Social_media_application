<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Profile - Threadline</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg: #0a0a0f;
            --surface: #111118;
            --surface-2: #18181f;
            --border: rgba(255,255,255,0.07);
            --border-strong: rgba(255,255,255,0.14);
            --accent: #e8ff47;
            --accent-2: #ff6b47;
            --text: #f0ede8;
            --muted: #6b6878;
            --soft: rgba(240,237,232,0.72);
            --success: rgba(105,255,97,0.76);
        }

        html { scroll-behavior: smooth; }

        body {
            min-height: 100vh;
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            background:
                radial-gradient(circle at top left, rgba(232,255,71,0.08), transparent 30%),
                radial-gradient(circle at 85% 20%, rgba(255,107,71,0.08), transparent 28%),
                linear-gradient(180deg, #0a0a0f 0%, #0d0d14 100%);
        }

        .serif { font-family: 'Playfair Display', serif; }

        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes floatGlow {
            0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
            50% { transform: translate3d(0, -8px, 0) scale(1.03); }
        }

        @keyframes ringPulse {
            0%, 100% { box-shadow: 0 0 0 0 rgba(232,255,71,0.18); }
            50% { box-shadow: 0 0 0 10px rgba(232,255,71,0.06); }
        }

        .page-shell {
            position: relative;
            overflow: hidden;
        }

        .page-shell::before,
        .page-shell::after {
            content: '';
            position: fixed;
            border-radius: 999px;
            filter: blur(12px);
            pointer-events: none;
            animation: floatGlow 10s ease-in-out infinite;
        }

        .page-shell::before {
            top: 110px;
            left: -140px;
            width: 340px;
            height: 340px;
            background: radial-gradient(circle, rgba(232,255,71,0.12), transparent 70%);
        }

        .page-shell::after {
            right: -130px;
            bottom: 70px;
            width: 320px;
            height: 320px;
            background: radial-gradient(circle, rgba(255,107,71,0.12), transparent 70%);
            animation-delay: -4s;
        }

        .navbar {
            position: sticky;
            top: 0;
            z-index: 100;
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 64px;
            padding: 0 40px;
            background: rgba(10,10,15,0.82);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
        }

        .nav-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            color: var(--text);
        }

        .nav-dot {
            width: 28px;
            height: 28px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            background: var(--accent);
        }

        .nav-name {
            font-family: 'Playfair Display', serif;
            font-size: 19px;
            font-weight: 700;
        }

        .nav-actions {
            display: flex;
            align-items: center;
            gap: 12px;
            color: var(--muted);
            font-size: 13px;
        }

        .nav-link {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 8px 14px;
            border: 1px solid var(--border);
            border-radius: 10px;
            color: var(--muted);
            text-decoration: none;
            transition: all 0.2s ease;
            background: rgba(255,255,255,0.03);
        }

        .nav-link:hover {
            color: var(--text);
            border-color: var(--border-strong);
            background: rgba(255,255,255,0.05);
        }

        .main {
            position: relative;
            z-index: 1;
            max-width: 1100px;
            margin: 0 auto;
            padding: 48px 40px 80px;
        }

        .fade-up { animation: fadeUp 0.55s cubic-bezier(0.22, 1, 0.36, 1) both; }
        .fade-up-1 { animation-delay: 0.05s; }
        .fade-up-2 { animation-delay: 0.15s; }
        .fade-up-3 { animation-delay: 0.25s; }

        .hero-card,
        .posts-wrap,
        .post-card {
            background: linear-gradient(180deg, rgba(17,17,24,0.98), rgba(13,13,19,0.98));
            border: 1px solid var(--border);
            box-shadow: 0 22px 60px rgba(0,0,0,0.32);
        }

        .hero-card {
            border-radius: 24px;
            overflow: visible;
        }

        .hero-cover {
            position: relative;
            min-height: 170px;
            background:
                radial-gradient(circle at 18% 24%, rgba(232,255,71,0.24), transparent 26%),
                radial-gradient(circle at 78% 28%, rgba(255,107,71,0.22), transparent 30%),
                linear-gradient(135deg, #18181f 0%, #111118 45%, #0d0d14 100%);
            border-bottom: 1px solid var(--border);
            border-radius: 24px 24px 0 0;
        }

        .hero-cover::after {
            content: '';
            position: absolute;
            inset: 0;
            background-image:
                linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
            background-size: 34px 34px;
            mask-image: linear-gradient(180deg, rgba(0,0,0,0.7), transparent);
        }

        .profile-body {
            padding: 0 32px 32px;
        }

        .profile-top {
            position: relative;
            z-index: 3;
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            gap: 24px;
            margin-top: -52px;
        }

        .profile-identity {
            display: flex;
            align-items: flex-end;
            gap: 18px;
        }

        .avatar-frame {
            position: relative;
            z-index: 4;
            width: 108px;
            height: 108px;
            padding: 4px;
            border-radius: 999px;
            background: linear-gradient(135deg, var(--accent), var(--accent-2));
            animation: ringPulse 3.2s ease-in-out infinite;
            box-shadow: 0 12px 34px rgba(0,0,0,0.35);
        }

        .avatar-frame img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            border-radius: 999px;
            background: var(--surface-2);
            border: 3px solid #0f0f16;
        }

        .eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 10px;
            font-size: 11px;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--accent);
            font-weight: 700;
        }

        .eyebrow::before {
            content: '';
            width: 22px;
            height: 1.5px;
            background: var(--accent);
        }

        .profile-name {
            font-family: 'Playfair Display', serif;
            font-size: 30px;
            line-height: 0.98;
            letter-spacing: -1.0px;
        }

        .profile-name span { color: var(--accent); }

        .profile-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 14px;
            font-size: 13px;
            color: var(--muted);
        }

        .profile-meta-item {
            display: inline-flex;
            align-items: center;
            gap: 7px;
        }

        .profile-bio {
            max-width: 700px;
            margin-top: 20px;
            font-size: 15px;
            line-height: 1.8;
            color: var(--soft);
        }

        .profile-bio.empty {
            color: var(--muted);
            font-style: italic;
        }

        .profile-bio a {
            color: var(--accent);
            text-decoration: none;
        }

        .action-btn {
            position: relative;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 18px;
            border-radius: 12px;
            font-size: 13px;
            font-weight: 600;
            text-decoration: none;
            transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
        }

        .action-btn.primary {
            background: var(--accent);
            color: #0a0a0f;
        }

        .action-btn.primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 14px 32px rgba(232,255,71,0.28);
        }

        .action-btn.secondary {
            color: var(--muted);
            background: rgba(255,255,255,0.03);
            border: 1px solid var(--border);
        }

        .action-btn.secondary:hover {
            color: var(--text);
            border-color: var(--border-strong);
            background: rgba(255,255,255,0.05);
            transform: translateY(-1px);
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 14px;
            margin-top: 28px;
        }

        .stat-card {
            padding: 18px 20px;
            border-radius: 16px;
            background: rgba(255,255,255,0.03);
            border: 1px solid var(--border);
        }

        .stat-card strong {
            display: block;
            font-family: 'Playfair Display', serif;
            font-size: 30px;
            line-height: 1;
            letter-spacing: -1px;
            color: var(--text);
        }

        .stat-card span {
            display: block;
            margin-top: 7px;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--muted);
            font-weight: 600;
        }

        .posts-wrap {
            margin-top: 34px;
            border-radius: 24px;
            padding: 28px;
        }

        .section-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            margin-bottom: 24px;
        }

        .section-title {
            font-family: 'Playfair Display', serif;
            font-size: clamp(28px, 4vw, 38px);
            letter-spacing: -1.3px;
        }

        .section-title span { color: var(--accent); }

        .count-pill {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 6px 12px;
            border-radius: 999px;
            background: rgba(255,255,255,0.05);
            border: 1px solid var(--border);
            font-size: 12px;
            color: var(--muted);
            font-weight: 600;
        }

        .posts-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 18px;
        }

        .post-card {
            border-radius: 18px;
            overflow: hidden;
            transition: transform 0.22s ease, border-color 0.22s ease, box-shadow 0.22s ease;
        }

        .post-card:hover {
            transform: translateY(-3px);
            border-color: var(--border-strong);
            box-shadow: 0 16px 44px rgba(0,0,0,0.42);
        }

        .post-accent {
            height: 4px;
            background: linear-gradient(90deg, var(--accent), var(--accent-2));
        }

        .post-inner {
            padding: 22px;
        }

        .post-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            margin-bottom: 14px;
        }

        .post-tag {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--accent);
            font-weight: 700;
        }

        .post-date {
            font-size: 11px;
            color: var(--success);
        }

        .post-content {
            font-size: 14px;
            line-height: 1.8;
            color: var(--soft);
            min-height: 84px;
            word-break: break-word;
        }

        .post-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            padding-top: 16px;
            margin-top: 18px;
            border-top: 1px solid var(--border);
        }

        .card-link {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            font-size: 12px;
            font-weight: 600;
            color: var(--accent);
            text-decoration: none;
        }

        .card-link:hover { color: var(--text); }

        .mini-actions {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .icon-btn {
            width: 34px;
            height: 34px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 10px;
            border: 1px solid var(--border);
            background: rgba(255,255,255,0.03);
            color: var(--muted);
            transition: all 0.2s ease;
        }

        .icon-btn:hover {
            color: var(--text);
            border-color: var(--border-strong);
            background: rgba(255,255,255,0.06);
        }

        .icon-btn.delete:hover {
            color: var(--accent-2);
            border-color: rgba(255,107,71,0.28);
            background: rgba(255,107,71,0.08);
        }

        .empty-state {
            position: relative;
            overflow: hidden;
            padding: 54px 28px;
            border-radius: 20px;
            text-align: center;
            background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.015));
            border: 1px dashed rgba(255,255,255,0.14);
        }

        .empty-state::before {
            content: '';
            position: absolute;
            inset: auto auto -70px -70px;
            width: 180px;
            height: 180px;
            background: radial-gradient(circle, rgba(232,255,71,0.12), transparent 70%);
            pointer-events: none;
        }

        .empty-icon {
            width: 72px;
            height: 72px;
            margin: 0 auto 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            background: linear-gradient(135deg, rgba(232,255,71,0.14), rgba(255,107,71,0.12));
            border: 1px solid rgba(255,255,255,0.08);
            color: var(--accent);
        }

        .empty-state h3 {
            font-family: 'Playfair Display', serif;
            font-size: 28px;
            letter-spacing: -1px;
            margin-bottom: 8px;
        }

        .empty-state p {
            font-size: 14px;
            color: var(--muted);
            margin-bottom: 22px;
        }

        .footer {
            padding: 0 40px 26px;
            text-align: center;
            font-size: 12px;
            color: var(--muted);
        }

        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #0a0a0f; }
        ::-webkit-scrollbar-thumb { background: #232330; border-radius: 999px; }

        @media (max-width: 900px) {
            .profile-top {
                flex-direction: column;
                align-items: flex-start;
                margin-top: -44px;
            }

            .profile-identity {
                align-items: center;
            }

            .stats-grid {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 640px) {
            .navbar,
            .main,
            .footer {
                padding-left: 20px;
                padding-right: 20px;
            }

            .nav-actions {
                gap: 8px;
            }

            .nav-link span {
                display: none;
            }

            .profile-body {
                padding: 0 20px 22px;
            }

            .profile-identity {
                flex-direction: column;
                align-items: flex-start;
                gap: 14px;
            }

            .avatar-frame {
                width: 92px;
                height: 92px;
            }

            .posts-wrap {
                padding: 20px;
            }

            .section-head {
                flex-direction: column;
                align-items: flex-start;
            }
        }
    </style>
</head>
<body>
    <div class="page-shell">
        <nav class="navbar">
            <a href="/feed" class="nav-brand">
                <div class="nav-dot">
                    <svg viewBox="0 0 16 16" width="14" height="14" fill="#0a0a0f">
                        <path d="M8 2L10.5 7H14L11 10L12.5 14L8 11.5L3.5 14L5 10L2 7H5.5L8 2Z"/>
                    </svg>
                </div>
                <span class="nav-name">Threadline</span>
            </a>

            <div class="nav-actions">
                <a href="/feed" class="nav-link">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M3 12l9-9 9 9"/>
                        <path d="M9 21V9h6v12"/>
                    </svg>
                    <span>Home</span>
                </a>
            </div>
        </nav>

        <main class="main">
            <section class="hero-card fade-up fade-up-1">
                <div class="hero-cover"></div>

                <div class="profile-body">
                    <div class="profile-top">
                        <div class="profile-identity">
                            <div class="avatar-frame">
                                <img src="/images/uploads/<%= user ? user.profilepic : 'default.png' %>" alt="Profile picture">
                            </div>

                            <div>
                                <!-- <span class="eyebrow">Profile Space</span> -->
                                <h1 class="profile-name mt-5"><span>@</span><%= user ? user.username : "guest" %></h1>
                                <div class="profile-meta">
                                    <span class="profile-meta-item">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M4 4h16v16H4z" opacity="0"/>
                                            <path d="M4 6l8 7 8-7"/>
                                            <rect x="3" y="5" width="18" height="14" rx="2"/>
                                        </svg>
                                        <%= user.email %>
                                    </span>
                                    <% if (user.name) { %>
                                    <span class="profile-meta-item">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M20 21a8 8 0 1 0-16 0"/>
                                            <circle cx="12" cy="7" r="4"/>
                                        </svg>
                                        <%= user.name %>
                                    </span>
                                    <% } %>
                                </div>
                            </div>
                        </div>

                        <a href="/profile/upload" class="action-btn primary">
                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 20 20" fill="currentColor">
                                <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"/>
                            </svg>
                            Update Profile
                        </a>
                    </div>

                    <% if (user.bio) { %>
                        <p class="profile-bio"><%= user.bio %></p>
                    <% } else { %>
                        <p class="profile-bio empty">No bio yet. Add a short intro in your profile flow so this page feels more like you.</p>
                    <% } %>

                    <div class="stats-grid">
                        <div class="stat-card">
                            <strong><%= user.posts.length %></strong>
                            <span>Posts Published</span>
                        </div>
                        <div class="stat-card">
                            <strong><%= user.followers !== undefined ? user.followers : 0 %></strong>
                            <span>Followers</span>
                        </div>
                        <div class="stat-card">
                            <strong><%= user.following !== undefined ? user.following : 0 %></strong>
                            <span>Following</span>
                        </div>
                    </div>
                </div>
            </section>

            <section class="posts-wrap fade-up fade-up-2">
                <div class="section-head">
                    <h2 class="section-title">Recent <span>posts</span></h2>
                    <div style="display:flex; align-items:center; gap:12px; flex-wrap:wrap;">
                        <span class="count-pill"><%= user.posts.length %> post<%= user.posts.length !== 1 ? 's' : '' %></span>
                        <% if (user.posts.length > 0) { %>
                        <a href="/feed" class="action-btn secondary">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M12 5v14M5 12h14"/>
                            </svg>
                            Start Writing
                        </a>
                        <% } %>
                    </div>
                </div>

                <% if (user.posts.length === 0) { %>
                    <div class="empty-state fade-up fade-up-3">
                        <div class="empty-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                <path d="M8 6h8"/>
                                <path d="M8 10h8"/>
                                <path d="M8 14h5"/>
                                <rect x="4" y="3" width="16" height="18" rx="2"/>
                            </svg>
                        </div>
                        <h3>Nothing published yet</h3>
                        <p>Start the first thread and this profile will light up with posts.</p>
                        <a href="/feed" class="action-btn primary">Write your first post</a>
                    </div>
                <% } else { %>
                    <div class="posts-grid">
                        <% user.posts.slice().reverse().forEach((post, index) => { %>
                            <article class="post-card fade-up" style="animation-delay: <%= 0.2 + index * 0.07 %>s">
                                <div class="post-accent" style="background: linear-gradient(90deg, <%= ['#e8ff47','#ff6b47','#7c6aff','#5eead4','#f59e0b'][index % 5] %>, <%= ['#ff6b47','#e8ff47','#60a5fa','#f472b6','#fb7185'][index % 5] %>);"></div>
                                <div class="post-inner">
                                    <div class="post-top">
                                        <span class="post-tag">Post #<%= user.posts.length - index %></span>
                                        <% if (post.createdAt || post.date) { %>
                                        <time class="post-date">
                                            <%= new Date(post.createdAt || post.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                                        </time>
                                        <% } %>
                                    </div>

                                    <p class="post-content"><%= post.content || post.description || '' %></p>

                                    <div class="post-footer">
                                        <a href="/edit/<%= post._id %>" class="card-link">
                                            Open editor
                                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 20 20" fill="currentColor">
                                                <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
                                            </svg>
                                        </a>

                                        <div class="mini-actions">
                                            <a href="/edit/<%= post._id %>" class="icon-btn" title="Edit post">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 20 20" fill="currentColor">
                                                    <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"/>
                                                </svg>
                                            </a>
                                            <form action="/delete/<%= post._id %>" method="POST" onsubmit="return confirm('Delete this post?')">
                                                <button type="submit" class="icon-btn delete" title="Delete post">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 20 20" fill="currentColor">
                                                        <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd"/>
                                                    </svg>
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </article>
                        <% }) %>
                    </div>
                <% } %>
            </section>
        </main>

        <footer class="footer">
            &copy; <%= new Date().getFullYear() %> Threadline · @<%= user.username %>
        </footer>
    </div>
</body>
</html>
