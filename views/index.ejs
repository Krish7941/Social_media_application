<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white ">
        <h3 class="text-2xl mb-6">Create Account</h3>
        <form action="/register" method="post" class="p-6 rounded-lg">
            <input class ="px-3 py-2 outline-none bg-transparent rounded-md border-2 border-zinc-800" type="text" placeholder="name" name="name" class="bg-zinc-600 text-white placeholder:text-zinc-400 border border-zinc-500 focus:outline-none focus:ring-2 focus:ring-blue-500">
            <input class ="px-3 py-2 outline-none bg-transparent rounded-md border-2 border-zinc-800" type="text" placeholder="username" name="username" class="bg-zinc-600 text-white placeholder:text-zinc-400 border border-zinc-500 focus:outline-none focus:ring-2 focus:ring-blue-500">
            <input class ="px-3 py-2 outline-none bg-transparent rounded-md border-2 border-zinc-800" type="number" placeholder="age" name="age" class="bg-zinc-600 text-white placeholder:text-zinc-400 border border-zinc-500 focus:outline-none focus:ring-2 focus:ring-blue-500">
            <input class ="px-3 py-2 outline-none bg-transparent rounded-md border-2 border-zinc-800" type="email" placeholder="email" name="email" class="bg-zinc-600 text-white placeholder:text-zinc-400 border border-zinc-500 focus:outline-none focus:ring-2 focus:ring-blue-500">
            <input class ="px-3 py-2 outline-none bg-transparent rounded-md border-2 border-zinc-800" type="password" placeholder="password" name="password">
            <input class ="px-3 py-2 bg-blue-500 text-sm rounded-md" type="submit" value="Create Account">
        </form>
    </div>
</body>
</html>